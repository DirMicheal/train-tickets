APP_PORT=3002
APP_HOST=0.0.0.0
NODE_ENV=development

JWT_SECRET=train-ticket-service-secret-key-2024-must-be-very-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

DB_TYPE=sqlite
DB_DATABASE=./data/train_ticket.db
DB_SYNCHRONIZE=true
DB_LOGGING=false

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

LOCK_TTL=5000
LOCK_RETRY_COUNT=3
LOCK_RETRY_DELAY=200

TICKET_LOCK_TTL=300
ORDER_EXPIRE_MINUTES=30

PAYMENT_TIMEOUT_MINUTES=15

MQ_CONCURRENCY=5

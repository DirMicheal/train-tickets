{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "entryFile": "main",
  "language": "ts",
  "compilerOptions": {
    "deleteOutDir": false,
    "tsConfigPath": "./tsconfig.build.json",
    "typeCheck": false,
    "builder": {
      "type": "swc",
      "options": {
        "swcrcPath": ".swcrc"
      }
    }
  }
}
